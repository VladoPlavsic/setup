#!/bin/bash

CONFIG="$HOME/.config/k8s.yaml"
LAST_FILE="$HOME/.cache/k8s-last"

# =============================================================================
# COLORS & FORMATTING
# =============================================================================

BOLD='\033[1m'
DIM='\033[2m'
CYAN='\033[36m'
GREEN='\033[32m'
YELLOW='\033[33m'
RED='\033[31m'
BG_RED='\033[41m'
RESET='\033[0m'

header() {
  echo -e "\n${BOLD}${CYAN}▸ $1${RESET}\n"
}

success() {
  echo -e "${GREEN}✓${RESET} $1"
}

prompt() {
  echo -en "${YELLOW}▸${RESET} $1"
}

warn_prod() {
  echo
  echo -e "  ${BG_RED}${BOLD}  ⚠  WARNING: PRODUCTION ENVIRONMENT  ⚠  ${RESET}"
  echo
  prompt "Type ${BOLD}yes${RESET} to confirm: "
  read confirm
  if [[ "$confirm" != "yes" ]]; then
    echo -e "${DIM}Aborted.${RESET}"
    exit 1
  fi
}

menu() {
  local title=$1
  shift
  local options=("$@")

  # Highlight PROD in red
  MENU_RESULT=$(printf '%s\n' "${options[@]}" | fzf --height=40% --reverse --header="$title" --ansi \
    --color="header:cyan:bold" \
    | cat)
  [[ -z "$MENU_RESULT" ]] && exit 1
}

# =============================================================================
# LAST SELECTION CACHE
# =============================================================================

save_last() {
  mkdir -p "$(dirname "$LAST_FILE")"
  echo "CLUSTER_ENV=$CLUSTER_ENV" > "$LAST_FILE"
  echo "CLUSTER=$CLUSTER" >> "$LAST_FILE"
}

load_last() {
  if [[ -f "$LAST_FILE" ]]; then
    source "$LAST_FILE"
    return 0
  fi
  return 1
}

# =============================================================================
# CONFIG HELPERS
# =============================================================================

get_binary_for_pod() {
  local pod=$1
  local services=$(yq -r '.services | keys[]' "$CONFIG")
  for svc in $services; do
    if [[ $pod == ${svc}-* ]]; then
      yq -r ".services.$svc" "$CONFIG"
      return
    fi
  done
}

get_context() {
  local env=$1 cluster=$2
  yq -r ".contexts.$cluster.$env // .contexts.$cluster" "$CONFIG"
}

requires_approval() {
  local env=$1 cluster=$2
  [[ "$env" == "PROD" ]] && yq -e ".prod_approval_required[] | select(. == \"$cluster\")" "$CONFIG" > /dev/null 2>&1
}

get_namespace() {
  local env=$1 cluster=$2
  local prefix=$(yq -r ".namespaces.$cluster" "$CONFIG")
  echo "${prefix}-$(echo "$env" | tr '[:upper:]' '[:lower:]')"
}

select_env_and_cluster() {
  local use_last=$1

  if [[ "$use_last" == "--last" ]]; then
    if load_last; then
      echo -e "${DIM}Using last selection: ${CLUSTER_ENV}/${CLUSTER}${RESET}"
      return 0
    else
      echo -e "${YELLOW}No previous selection found${RESET}"
    fi
  fi

  local envs=($(yq -r '.environments[]' "$CONFIG"))
  menu "Select Environment" "${envs[@]}"
  CLUSTER_ENV="$MENU_RESULT"

  local clusters=($(yq -r ".clusters.$CLUSTER_ENV[]" "$CONFIG"))
  menu "Select Cluster" "${clusters[@]}"
  CLUSTER="$MENU_RESULT"

  save_last
}

select_pod() {
  local ns=$1
  POD=$(kubectl -n "$ns" get po --no-headers | fzf --height=40% --reverse --header="Select Pod (${ns})" | awk '{print $1}')
  [[ -z "$POD" ]] && exit 1
}

show_pods() {
  local ns=$1
  header "Pods in ${ns}"
  kubectl -n "$ns" get po
  echo
}

# =============================================================================
# COMMANDS
# =============================================================================

cmd_ctx() {
  local env=$1 cluster=$2

  if [[ -z $env || -z $cluster ]]; then
    select_env_and_cluster "$1"
    env=$CLUSTER_ENV
    cluster=$CLUSTER
  else
    # Direct call with args - still warn for PROD
    if [[ "$env" == "PROD" ]]; then
      warn_prod
    fi
    CLUSTER_ENV=$env
    CLUSTER=$cluster
    save_last
  fi

  echo "$cluster" | tsh-login-dev >> /dev/null

  local context=$(get_context "$env" "$cluster")
  kubectl config use-context "$context" > /dev/null
  success "Switched to ${BOLD}${env}/${cluster}${RESET}"

  if requires_approval "$env" "$cluster"; then
    header "Pending Requests"
    tsh requests ls
    echo
    prompt "Enter request-id: "
    read REQUEST_ID
    tsh login --request-id="$REQUEST_ID"
  fi
}

cmd_ls() {
  local flag=$1
  select_env_and_cluster "$flag"
  cmd_ctx "$CLUSTER_ENV" "$CLUSTER"

  local ns=$(get_namespace "$CLUSTER_ENV" "$CLUSTER")
  show_pods "$ns"
}

cmd_connect() {
  local flag=$1
  select_env_and_cluster "$flag"
  cmd_ctx "$CLUSTER_ENV" "$CLUSTER"

  local ns=$(get_namespace "$CLUSTER_ENV" "$CLUSTER")
  select_pod "$ns"

  local binary=$(get_binary_for_pod "$POD")
  if [[ -n $binary ]]; then
    echo
    success "Connecting to ${BOLD}${POD}${RESET}..."
    echo
    kubectl -n "$ns" exec -it "$POD" -- $binary remote
  else
    echo -e "\n${YELLOW}Unknown service for pod:${RESET} $POD"
    exit 1
  fi
}

cmd_logs() {
  local tail="100"
  local follow=true
  local use_last=""
  local args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tail=*) tail="${1#--tail=}"; shift ;;
      --tail)   tail="$2"; shift 2 ;;
      --no-follow|-F) follow=false; shift ;;
      --last) use_last="--last"; shift ;;
      *) args+=("$1"); shift ;;
    esac
  done

  # Redirect interactive output to stderr so logs can be piped
  select_env_and_cluster "$use_last" >&2
  cmd_ctx "$CLUSTER_ENV" "$CLUSTER" >&2

  local ns=$(get_namespace "$CLUSTER_ENV" "$CLUSTER")
  select_pod "$ns" >&2

  echo -e "\n${DIM}─── logs: ${POD} (tail=${tail}, follow=${follow}) ───${RESET}\n" >&2

  local cmd=(kubectl -n "$ns" logs "--tail=$tail")
  [[ "$follow" == true ]] && cmd+=(-f)
  cmd+=("$POD" "${args[@]}")

  "${cmd[@]}"
}

cmd_status() {
  echo
  if load_last; then
    local ns=$(get_namespace "$CLUSTER_ENV" "$CLUSTER")
    local pod_count=$(kubectl -n "$ns" get po --no-headers 2>/dev/null | wc -l | tr -d ' ')
    local running=$(kubectl -n "$ns" get po --no-headers 2>/dev/null | grep -c Running)

    local env_color="$GREEN"
    [[ "$CLUSTER_ENV" == "PROD" ]] && env_color="$RED"
    [[ "$CLUSTER_ENV" == "UAT" ]] && env_color="$YELLOW"

    echo -e "  ${BOLD}Environment:${RESET}  ${env_color}${CLUSTER_ENV}${RESET}"
    echo -e "  ${BOLD}Cluster:${RESET}      ${CLUSTER}"
    echo -e "  ${BOLD}Namespace:${RESET}    ${ns}"
    echo -e "  ${BOLD}Pods:${RESET}         ${running}/${pod_count} running"
    echo
    echo -e "  ${DIM}Context: $(kubectl config current-context 2>/dev/null)${RESET}"
  else
    echo -e "  ${DIM}No context selected yet. Run ${RESET}${BOLD}k8s ctx${RESET}${DIM} first.${RESET}"
  fi
  echo
}

_wait_for_port() {
  local port=$1
  local retries=20
  while ! nc -z localhost "$port" 2>/dev/null; do
    retries=$((retries - 1))
    [[ $retries -eq 0 ]] && { echo -e "${RED}Port $port never became ready.${RESET}" >&2; return 1; }
    sleep 0.3
  done
}

_port_forward() {
  local pod=$1 ns=$2 local_port=$3 container_port=$4
  kubectl port-forward "pod/$pod" -n "$ns" "$local_port:$container_port" >/dev/null &
  _PFORWARD_PID=$!
  _wait_for_port "$local_port" >&2
}

_cleanup_port_forward() {
  echo -e "\n${DIM}Stopping...${RESET}" >&2
  kill "$_PFORWARD_PID" 2>/dev/null || true
  _PFORWARD_PID=""
}

cmd_subscribe() {
  local use_last=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --last) use_last="--last"; shift ;;
      *) shift ;;
    esac
  done

  select_env_and_cluster "$use_last" >&2
  cmd_ctx "$CLUSTER_ENV" "$CLUSTER" >&2

  local ns=$(get_namespace "$CLUSTER_ENV" "$CLUSTER")
  select_pod "$ns" >&2

  prompt "Charger identity: " >&2
  read -r IDENTITY
  [[ -z "$IDENTITY" ]] && { echo -e "${RED}Identity required.${RESET}" >&2; exit 1; }

  prompt "External ID: " >&2
  read -r EXTERNAL_ID
  [[ -z "$EXTERNAL_ID" ]] && { echo -e "${RED}External ID required.${RESET}" >&2; exit 1; }

  local DEFAULT_FILE="${POD}_${IDENTITY}_${EXTERNAL_ID}_subscription.log"
  prompt "Output file [${DEFAULT_FILE}]: " >&2
  read -r INPUT_FILE
  local OUTPUT_FILE="${INPUT_FILE:-$DEFAULT_FILE}"

  local CONTAINER_PORT
  CONTAINER_PORT=$(kubectl get pod "$POD" -n "$ns" -o jsonpath='{.spec.containers[0].ports[0].containerPort}')
  local LOCAL_PORT
  LOCAL_PORT=$(python3 -c "import socket; s=socket.socket(); s.bind(('',0)); print(s.getsockname()[1]); s.close()")

  echo >&2
  echo -e "  ${BOLD}Pod:${RESET}        $POD" >&2
  echo -e "  ${BOLD}Identity:${RESET}   $IDENTITY" >&2
  echo -e "  ${BOLD}External ID:${RESET} $EXTERNAL_ID" >&2
  echo -e "  ${BOLD}Output:${RESET}     $OUTPUT_FILE" >&2
  echo -e "  ${BOLD}Forward:${RESET}    localhost:$LOCAL_PORT -> $POD:$CONTAINER_PORT" >&2
  echo >&2

  _port_forward "$POD" "$ns" "$LOCAL_PORT" "$CONTAINER_PORT" >&2
  trap _cleanup_port_forward EXIT
  trap 'exit 130' INT
  trap 'exit 143' TERM

  local QUERY
  QUERY="subscription { package(identity: \\\"$IDENTITY\\\", externalId: \\\"$EXTERNAL_ID\\\") { id rawContent parsedContent protocol source sender receiver timestamp identity externalId additionalData { identity externalId } } }"

  success "Subscribed — streaming to ${BOLD}${OUTPUT_FILE}${RESET} (Ctrl+C to stop)" >&2

  (
    sleep 0.3
    echo '{"topic":"phoenix","event":"heartbeat","payload":{},"ref":"1","join_ref":null}'
    sleep 0.3
    echo '{"topic":"__absinthe__:control","event":"phx_join","payload":{},"ref":"2","join_ref":"2"}'
    sleep 0.3
    printf '{"topic":"__absinthe__:control","event":"doc","payload":{"query":"%s"},"ref":"3","join_ref":"2"}\n' "$QUERY"
    ref=4
    while true; do
      sleep 30
      printf '{"topic":"phoenix","event":"heartbeat","payload":{},"ref":"%s","join_ref":null}\n' "$ref"
      ref=$((ref + 1))
    done
  ) | websocat -n "ws://localhost:$LOCAL_PORT/graphql/websocket" | tee "$OUTPUT_FILE"
}

cmd_query() {
  local use_last=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --last) use_last="--last"; shift ;;
      *) shift ;;
    esac
  done

  select_env_and_cluster "$use_last" >&2
  cmd_ctx "$CLUSTER_ENV" "$CLUSTER" >&2

  local ns=$(get_namespace "$CLUSTER_ENV" "$CLUSTER")
  select_pod "$ns" >&2

  menu "Select source" "TIMETICK" "OCS" >&2
  local SOURCE="$MENU_RESULT"

  prompt "Charger identity: " >&2
  read -r IDENTITY
  [[ -z "$IDENTITY" ]] && { echo -e "${RED}Identity required.${RESET}" >&2; exit 1; }

  prompt "Period — last N minutes [60]: " >&2
  read -r MINUTES
  MINUTES="${MINUTES:-60}"

  local FROM TO
  FROM=$(date -u -v-${MINUTES}M +"%Y-%m-%dT%H:%M:%SZ")
  TO=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

  local DEFAULT_FILE="${POD}_${IDENTITY}_${SOURCE}_query.json"
  prompt "Output file [${DEFAULT_FILE}]: " >&2
  read -r INPUT_FILE
  local OUTPUT_FILE="${INPUT_FILE:-$DEFAULT_FILE}"

  local CONTAINER_PORT
  CONTAINER_PORT=$(kubectl get pod "$POD" -n "$ns" -o jsonpath='{.spec.containers[0].ports[0].containerPort}')
  local LOCAL_PORT
  LOCAL_PORT=$(python3 -c "import socket; s=socket.socket(); s.bind(('',0)); print(s.getsockname()[1]); s.close()")

  echo >&2
  echo -e "  ${BOLD}Pod:${RESET}       $POD" >&2
  echo -e "  ${BOLD}Source:${RESET}    $SOURCE" >&2
  echo -e "  ${BOLD}Identity:${RESET}  $IDENTITY" >&2
  echo -e "  ${BOLD}Period:${RESET}    $FROM → $TO" >&2
  echo -e "  ${BOLD}Output:${RESET}    $OUTPUT_FILE" >&2
  echo >&2

  _port_forward "$POD" "$ns" "$LOCAL_PORT" "$CONTAINER_PORT" >&2
  trap _cleanup_port_forward EXIT
  trap 'exit 130' INT
  trap 'exit 143' TERM

  local GQL_QUERY='query Packages($filter: FilterByPackage!, $pagination: PagePaginationParams) { packages(filter: $filter, pagination: $pagination) { records { id rawContent parsedContent protocol source sender receiver timestamp identity externalId additionalData { identity externalId } } pagination { pageNumber pageSize totalPages totalEntries } } }'
  local PAGE=1
  local PAGE_SIZE=20
  local TOTAL_PAGES=1
  local ALL_RECORDS="[]"

  success "Querying packages ($FROM → $TO)..." >&2

  while [[ $PAGE -le $TOTAL_PAGES ]]; do
    echo -e "  ${DIM}Fetching page $PAGE/$TOTAL_PAGES...${RESET}" >&2

    local BODY
    BODY=$(jq -n \
      --arg identity "$IDENTITY" \
      --arg source "$SOURCE" \
      --arg from "$FROM" \
      --arg to "$TO" \
      --argjson page "$PAGE" \
      --argjson pageSize "$PAGE_SIZE" \
      --arg query "$GQL_QUERY" \
      '{
        query: $query,
        variables: {
          filter: {
            identities: [$identity],
            source: $source,
            period: { from: $from, to: $to }
          },
          pagination: { page: $page, pageSize: $pageSize }
        }
      }')

    local RESPONSE
    RESPONSE=$(curl -s -X POST "http://localhost:$LOCAL_PORT/graphql" \
      -H "Content-Type: application/json" \
      -d "$BODY")

    if [[ -z "$RESPONSE" ]]; then
      echo -e "${RED}Empty response from server.${RESET}" >&2
      exit 1
    fi

    if echo "$RESPONSE" | jq -e '.errors' >/dev/null 2>&1; then
      echo -e "${RED}GraphQL error:${RESET}" >&2
      echo "$RESPONSE" | jq '.errors' >&2
      exit 1
    fi

    TOTAL_PAGES=$(echo "$RESPONSE" | jq '.data.packages.pagination.totalPages // 1')
    local RECORDS
    RECORDS=$(echo "$RESPONSE" | jq '.data.packages.records // []')
    ALL_RECORDS=$(jq -n --argjson a "$ALL_RECORDS" --argjson b "$RECORDS" '$a + $b')

    PAGE=$((PAGE + 1))
  done

  local TOTAL
  TOTAL=$(echo "$ALL_RECORDS" | jq 'length')
  echo >&2

  local OUTPUT
  OUTPUT=$(jq -n --argjson records "$ALL_RECORDS" --argjson total "$TOTAL" \
    '{totalRecords: $total, records: $records}')

  if [[ -z "$OUTPUT" ]]; then
    echo -e "${RED}Failed to build output JSON.${RESET}" >&2
    echo -e "${DIM}ALL_RECORDS preview: ${ALL_RECORDS:0:200}${RESET}" >&2
    exit 1
  fi

  echo "$OUTPUT" | tee "$OUTPUT_FILE"
  echo >&2
  success "Saved $TOTAL records to ${BOLD}${OUTPUT_FILE}${RESET}" >&2
}

cmd_completion() {
  cat <<'COMPLETION'
# k8s completion - add to ~/.bashrc or ~/.zshrc:
#   source <(k8s completion)

_k8s_completions() {
  local cur="${COMP_WORDS[COMP_CWORD]}"
  local prev="${COMP_WORDS[COMP_CWORD-1]}"
  local cmd="${COMP_WORDS[1]}"

  if [[ $COMP_CWORD -eq 1 ]]; then
    COMPREPLY=($(compgen -W "ctx ls connect logs subscribe query status completion help --last" -- "$cur"))
    return
  fi

  case "$cmd" in
    ctx)
      if [[ $COMP_CWORD -eq 2 ]]; then
        local envs=$(yq -r '.environments[]' "$HOME/.config/k8s-scripts.yaml" 2>/dev/null)
        COMPREPLY=($(compgen -W "$envs --last" -- "$cur"))
      elif [[ $COMP_CWORD -eq 3 ]]; then
        local env="${COMP_WORDS[2]}"
        local clusters=$(yq -r ".clusters.$env[]" "$HOME/.config/k8s-scripts.yaml" 2>/dev/null)
        COMPREPLY=($(compgen -W "$clusters" -- "$cur"))
      fi
      ;;
    ls|connect|subscribe|query)
      COMPREPLY=($(compgen -W "--last" -- "$cur"))
      ;;
    logs)
      COMPREPLY=($(compgen -W "--last --tail= --no-follow -F -c" -- "$cur"))
      ;;
  esac
}

# Bash
if [[ -n "$BASH_VERSION" ]]; then
  complete -F _k8s_completions k8s
fi

# Zsh
if [[ -n "$ZSH_VERSION" ]]; then
  autoload -U +X bashcompinit && bashcompinit
  complete -F _k8s_completions k8s
fi
COMPLETION
}

cmd_help() {
  echo -e "${BOLD}${CYAN}k8s${RESET} - Kubernetes helper commands\n"
  echo -e "${BOLD}Usage:${RESET} k8s <command> [args]\n"

  echo -e "${BOLD}Commands:${RESET}"
  echo -e "  ${BOLD}ctx${RESET} [ENV CLUSTER]  Switch kubectl context"
  echo -e "  ${BOLD}ls${RESET}                 List pods"
  echo -e "  ${BOLD}connect${RESET}            Connect to pod's remote console"
  echo -e "  ${BOLD}logs${RESET} [options]     Follow pod logs"
  echo -e "  ${BOLD}subscribe${RESET}          Subscribe to charger updates via WebSocket"
  echo -e "  ${BOLD}query${RESET}              Query packages from DB via GraphQL"
  echo -e "  ${BOLD}status${RESET}             Show current context info"
  echo -e "  ${BOLD}completion${RESET}         Output shell completion script"
  echo

  echo -e "${BOLD}Global options:${RESET}"
  echo -e "  ${DIM}--last${RESET}             Use last environment/cluster selection"
  echo

  echo -e "${BOLD}Logs options:${RESET}"
  echo -e "  ${DIM}--tail=N${RESET}           Lines to show (default: 100)"
  echo -e "  ${DIM}--no-follow, -F${RESET}    Don't follow logs"
  echo

  echo -e "${BOLD}Examples:${RESET}"
  echo -e "  ${DIM}\$${RESET} k8s ctx"
  echo -e "  ${DIM}\$${RESET} k8s ctx DEV TT"
  echo -e "  ${DIM}\$${RESET} k8s ls --last"
  echo -e "  ${DIM}\$${RESET} k8s connect --last"
  echo -e "  ${DIM}\$${RESET} k8s logs | grep error"
  echo -e "  ${DIM}\$${RESET} k8s status"
  echo
  echo -e "${BOLD}Setup completion:${RESET}"
  echo -e "  ${DIM}\$${RESET} echo 'source <(k8s completion)' >> ~/.bashrc"
}

# =============================================================================
# MAIN
# =============================================================================

case "${1:-help}" in
  ctx)        shift; cmd_ctx "$@" ;;
  ls)         cmd_ls "$2" ;;
  connect)    cmd_connect "$2" ;;
  subscribe)  shift; cmd_subscribe "$@" ;;
  query)      shift; cmd_query "$@" ;;
  logs)       shift; cmd_logs "$@" ;;
  status)     cmd_status ;;
  completion) cmd_completion ;;
  help|-h|--help) cmd_help ;;
  *)
    echo -e "${YELLOW}Unknown command:${RESET} $1\n"
    cmd_help
    exit 1
    ;;
esac
